# =============================================================================
# Voyage BI Copilot — environment variable reference
# Copy this file to .env and fill in the values. Never commit .env.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM providers
# -----------------------------------------------------------------------------

# Required. Anthropic API key for Claude (primary model).
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional. OpenAI API key for the GPT-4o fallback model.
# If absent, the fallback path is disabled.
OPENAI_API_KEY=your-openai-api-key-here

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# Admin role — used by scripts/seed.py and migrations.
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql://voyage:voyage@localhost:5432/voyage

# Read-only role — used exclusively by the MCP warehouse server.
# The bi_copilot_ro role has SELECT on the warehouse schema only.
RO_DATABASE_URL=postgresql://bi_copilot_ro:voyage_ro@localhost:5432/voyage

# -----------------------------------------------------------------------------
# Model selection
# -----------------------------------------------------------------------------

# Primary model used for all LLM calls.
MODEL_PRIMARY=claude-opus-4-6

# Fallback model if the primary is unavailable or over quota.
MODEL_FALLBACK=gpt-4o

# -----------------------------------------------------------------------------
# Safety and execution limits
# -----------------------------------------------------------------------------

# Maximum Postgres EXPLAIN cost allowed before a query is rejected.
# Postgres internal cost units — not wall-clock milliseconds.
MAX_COST=10000

# Hard row cap applied to every run_query call.
ROW_LIMIT=1000

# Statement-level timeout for SQL execution, in milliseconds.
STATEMENT_TIMEOUT_MS=10000
