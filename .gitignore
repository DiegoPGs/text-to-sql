# =============================================================================
# Voyage BI Copilot — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Environment / secrets — NEVER commit these
# -----------------------------------------------------------------------------
.env
.env.*.local

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
.venv/
venv/
env/
.Python

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
MANIFEST

# -----------------------------------------------------------------------------
# Type checker and linter caches
# -----------------------------------------------------------------------------
.mypy_cache/
.ruff_cache/
.dmypy.json
dmypy.json

# -----------------------------------------------------------------------------
# Test and coverage
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
coverage.xml
htmlcov/
*.coveragerc.bak

# -----------------------------------------------------------------------------
# Project runtime artifacts
# -----------------------------------------------------------------------------

# Structured run logs (written by the CLI at runtime)
logs/

# Eval report — regenerated by `make eval`; committing it would cause
# spurious diffs on every eval run
evals/latest.md

# SBOM files produced by `make sbom` / release.yml
*.sbom.json
*.cyclonedx.json

# -----------------------------------------------------------------------------
# IDE and editors
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# OS artifacts
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
# Keep docker-compose.yml tracked; ignore local override files
docker-compose.override.yml

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.log
*.tmp
*.bak
